@{
    ViewData["Title"] = "لوحة التحكم";
}

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold">لوحة القيادة</h1>
    <p class="text-muted">مرحباً بك في نظام إدارة مشاريعك الذكي.</p>
</div>

<div class="row">
    <!-- بطاقة العملاء -->
    <div class="col-md-6 mb-4">
        <div class="card text-white bg-primary shadow-sm h-100">
            <div class="card-header fs-5">إجمالي العملاء</div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <h2 class="display-3 fw-bold m-0">@ViewBag.TotalClients</h2>
            </div>
        </div>
    </div>

    <!-- بطاقة المواقع -->
    <div class="col-md-6 mb-4">
        <div class="card text-white bg-success shadow-sm h-100">
            <div class="card-header fs-5">إجمالي المواقع</div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <h2 class="display-3 fw-bold m-0">@ViewBag.TotalWebsites</h2>
            </div>
        </div>
    </div>
</div>