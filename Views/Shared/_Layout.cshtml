<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - لوحة القيادة</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
            body { background-color: #f8f9fc; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
            .wrapper { display: flex; min-height: 100vh; }

            /* تصميم القائمة الجانبية (Sidebar) */
            .sidebar { min-width: 260px; max-width: 260px; background-color: #4e73df; background-image: linear-gradient(180deg, #2c3e50 10%, #1a252f 100%); color: #fff; transition: all 0.3s;}
            .sidebar-brand { padding: 1.5rem 1rem; text-align: center; font-size: 1.4rem; font-weight: bold; border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 1rem;}
            .sidebar a { color: rgba(255,255,255,0.8); text-decoration: none; padding: 12px 20px; display: block; font-weight: 500; transition: 0.2s;}
            .sidebar a:hover { color: #fff; background-color: rgba(255,255,255,0.1); border-right: 4px solid #3498db; }

            /* القوائم المنسدلة في الجانب */
            .sidebar .dropdown-menu { background-color: rgba(0,0,0,0.15); border: none; margin: 0; padding: 0; border-radius: 0;}
            .sidebar .dropdown-menu a { padding: 10px 30px; font-size: 0.9rem; border-right: none;}
            .sidebar .dropdown-menu a:hover { background-color: rgba(0,0,0,0.2); border-right: 4px solid #e74c3c;}

            /* محتوى الموقع الأساسي */
            .content-wrapper { flex-grow: 1; display: flex; flex-direction: column; overflow: hidden; }
            .topbar { background-color: #fff; box-shadow: 0 .15rem 1.75rem 0 rgba(58,59,69,.15); height: 4.5rem; display: flex; align-items: center; padding: 0 2rem; justify-content: space-between; margin-bottom: 2rem;}
            .main-content { padding: 0 2rem; flex-grow: 1; }

            /* تصميم البطاقات لتصبح عصرية */
            .card { border: none; border-radius: 10px; transition: transform 0.2s; }
            .card:hover { transform: translateY(-3px); }
    </style>
</head>
<body>
    <div class="wrapper">
        <nav class="sidebar shadow">
            <div class="sidebar-brand">
                🚀 مدير المشاريع
            </div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Index">📊 الإحصائيات الرئيسية</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="#" data-bs-toggle="collapse" data-bs-target="#systemCollapse">
                        📂 إدارة النظام
                    </a>
                    <div class="collapse show" id="systemCollapse">
                        <div class="dropdown-menu show" style="position: static; float: none;">
                            <a asp-controller="Clients" asp-action="Index">👥 العملاء</a>
                            <a asp-controller="Websites" asp-action="Index">🌐 المواقع والنطاقات</a>
                            <a asp-controller="TeamMembers" asp-action="Index">👨‍💻 فريق العمل</a>
                            <a asp-controller="TaskItems" asp-action="Index">✅ المهام</a>
                        </div>
                    </div>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="#" data-bs-toggle="collapse" data-bs-target="#aboutCollapse">
                        ℹ️ معلومات إضافية
                    </a>
                    <div class="collapse" id="aboutCollapse">
                        <div class="dropdown-menu show" style="position: static; float: none;">
                            <a href="#">من نحن</a>
                            <a href="#">تواصل معنا</a>
                            <a href="#">سياسة الخصوصية</a>
                        </div>
                    </div>
                </li>
            </ul>
        </nav>

        <div class="content-wrapper">
            <header class="topbar">
                <div>
                    <h5 class="m-0 text-dark fw-bold">لوحة التحكم</h5>
                </div>
                <div class="d-flex align-items-center">
                    <span class="me-3 d-none d-lg-inline text-secondary small">المدير العام</span>
                    <img class="img-profile rounded-circle shadow-sm" src="https://ui-avatars.com/api/?name=Admin&background=2c3e50&color=fff" width="45" height="45">
                </div>
            </header>

            <main class="main-content">
                @RenderBody()
            </main>

            <footer class="bg-white text-center py-3 mt-auto shadow-sm border-top">
                <span class="text-muted small">بُني بشغف &copy; 2026</span>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>